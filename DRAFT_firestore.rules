rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- User Profiles ---
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) 
        && incoming().email is string
        && incoming().createdAt == request.time;
      allow update: if isOwner(userId)
        && incoming().diff(existing()).affectedKeys().hasOnly(['displayName']);
    }

    // --- Study Materials ---
    match /materials/{materialId} {
      function isValidMaterial(data) {
        return data.userId == request.auth.uid
          && data.fileName is string && data.fileName.size() < 256
          && data.originalContent is string && data.originalContent.size() < 1000000
          && (data.course == null || (data.course is string && data.course.size() < 100));
      }

      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isSignedIn() 
        && isValidMaterial(incoming())
        && incoming().createdAt == request.time;
        
      allow update: if isSignedIn() 
        && existing().userId == request.auth.uid
        && isValidMaterial(incoming())
        && (
          // Action: Rename or Update Summary/AI content
          incoming().diff(existing()).affectedKeys().hasAny(['fileName', 'summary', 'mnemonics', 'practiceQuestions', 'course'])
        );
        
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }
  }
}
